{
  "expo": {
    "name": "Cook'US",
    "slug": "cook-us",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cookus-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/cookus-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6E7"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/cookus-icon.png",
        "backgroundColor": "#FDF6E7"
      }
    },
    "scheme": "cook-us",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      "@react-native-community/datetimepicker"
    ]
  }
}
