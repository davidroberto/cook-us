#!/usr/bin/env sh

set -e

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

echo "=== Backend: lint ==="
cd backend && npm run lint

echo "=== Backend: build (typecheck) ==="
npm run build

echo "=== Frontend: lint ==="
cd ../frontend && npm run lint

echo "=== Frontend: build (typecheck) ==="
npm run build

echo "=== E2E tests ==="
cd ../e2e
if curl -s --head http://localhost:8080 | grep -q "200"; then
  npm run test:e2e
else
  echo "L'app n'est pas en cours d'exécution. Veuillez démarrer l'application avant de push"
  exit 1
fi

echo "=== All checks passed ==="
